---
import { DateTime } from 'luxon';
import ChangelogBanner from '../components/ChangelogBanner.astro';
import FeaturedItems from '../components/FeaturedItems/FeaturedItems.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import {
  isNewRoadmap,
  listOfficialRoadmaps,
} from '../queries/official-roadmap';

const roadmaps = await listOfficialRoadmaps();
const roleRoadmaps = roadmaps.filter((roadmap) => roadmap.type === 'role');
const skillRoadmaps = roadmaps.filter((roadmap) => roadmap.type === 'skill');
---

<BaseLayout
  title='VLSI Korea Roadmaps — Semiconductor Career Paths'
  description='Semiconductor design career roadmaps for students and engineers. STA, Physical Design, RTL, Verification, Analog, DFT, EDA.'
  permalink={'/'}
>
  <div slot='ad-slot-script'></div>
  <div slot='ad-slot'></div>

  <div class='bg-linear-to-b from-blue-950 to-black'>
    <div class='container py-16 text-center sm:py-24'>
      <h1 class='mb-4 text-4xl font-bold text-white sm:text-5xl'>VLSI Korea Roadmaps</h1>
      <p class='mx-auto max-w-2xl text-lg text-gray-300'>
        Semiconductor design career paths for students, junior engineers, and experienced professionals.
        Master STA, Physical Design, RTL, Verification, Analog, DFT, and EDA toolflows.
      </p>
      <div class='mt-8'>
        <a href='/career-graph' class='inline-block rounded-md bg-orange-500 px-6 py-3 text-white font-medium hover:bg-orange-400 transition-colors text-lg'>
          Explore the Career Graph →
        </a>
        <a href='/sta' class='ml-3 inline-block rounded-md border border-slate-600 px-6 py-3 text-white font-medium hover:bg-slate-800 transition-colors text-lg'>
          Start with STA
        </a>
      </div>

      <div class='mx-auto mt-10 max-w-md'>
        <input
          type='search'
          id='roadmap-search'
          placeholder='Search roadmaps...'
          aria-label='Search roadmaps'
          class='w-full rounded-md border border-slate-700 bg-slate-900 px-4 py-2.5 text-sm text-white placeholder:text-slate-500 focus:border-blue-400 focus:outline-none'
        />
      </div>
    </div>

    <p id='roadmap-search-empty' class='hidden py-10 text-center text-sm text-slate-400'>
      No roadmaps match your search.
    </p>

    <FeaturedItems
      heading='Role-based Roadmaps'
      featuredItems={roleRoadmaps.map((roadmapItem) => {
        const isNew = isNewRoadmap(roadmapItem.createdAt);
        return {
          text: roadmapItem.title.card,
          url: `/${roadmapItem.slug}`,
          isNew,
        };
      })}
      showCreateRoadmap={false}
    />

    <FeaturedItems
      heading='Skill-based Roadmaps'
      featuredItems={skillRoadmaps.map((roadmapItem) => {
        const isNew = isNewRoadmap(roadmapItem.createdAt);
        return {
          text: roadmapItem.title.card,
          url: `/${roadmapItem.slug}`,
          isNew,
        };
      })}
      showCreateRoadmap={false}
    />
  </div>
  <ChangelogBanner slot='changelog-banner' />
</BaseLayout>

<script>
  const input = document.getElementById('roadmap-search');
  const sections = document.querySelectorAll('[data-search-section]');
  const emptyMessage = document.getElementById('roadmap-search-empty');

  input?.addEventListener('input', () => {
    const query = input.value.trim().toLowerCase();
    let totalVisible = 0;

    sections.forEach((section) => {
      const items = section.querySelectorAll('[data-search-item]');
      let visibleInSection = 0;

      items.forEach((item) => {
        const text = item.getAttribute('data-search-text') ?? '';
        const matches = text.includes(query);
        item.classList.toggle('hidden', !matches);
        if (matches) visibleInSection++;
      });

      section.classList.toggle('hidden', visibleInSection === 0);
      totalVisible += visibleInSection;
    });

    emptyMessage?.classList.toggle('hidden', totalVisible > 0);
  });
</script>
